{
  "entities": {
    "ContactMessage": {
      "title": "Contact Message",
      "description": "A message submitted through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "maxLength": 100 },
        "email": { "type": "string", "maxLength": 150 },
        "phone": { "type": "string", "maxLength": 50, "nullable": true },
        "message": { "type": "string", "maxLength": 2000 },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "contact_messages/{messageId}": {
      "schema": { "$ref": "#/entities/ContactMessage" },
      "description": "Messages from the contact form."
    }
  }
}
